# ─── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Groq AI (required for AI Coach, Break My Startup, Generate Roadmap) ──────
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── PostHog Analytics (required for analytics) ───────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Stripe (required for payments) ──────────────────────────────────────────
NEXT_PUBLIC_CHECKOUT_URL=https://buy.stripe.com/your_link_here

# ─── Python backend (optional — AI fallback only) ─────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://your-backend.onrender.com/api/v1
