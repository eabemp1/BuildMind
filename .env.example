# ─── AI (required) ────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Database (SQLite default, PostgreSQL for production) ─────────────────────
DATABASE_URL=sqlite:///./buildmind.db
# DATABASE_URL=postgresql://user:password@host:5432/buildmind

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Supabase JWT secret — from Supabase dashboard → Settings → API → JWT Secret
# Used to validate Supabase-issued tokens on the Python backend
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Internal signing key (used only for legacy /auth/login — not for production)
SECRET_KEY=change-this-to-a-random-64-char-string
JWT_SECRET=change-this-to-a-random-64-char-string

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins — no wildcards
FRONTEND_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ─── Scheduler ────────────────────────────────────────────────────────────────
ENABLE_WEEKLY_REPORT_CRON=1
